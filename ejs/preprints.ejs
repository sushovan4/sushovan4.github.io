<div class="list post-items"><% for (const item of items) { %><div class="item" data-categories="<%= item.categories %>"><div class="thumbnail"><a href="<%- item.image || 'images/cover.jpg' %>"><img src="<%- item.image || 'images/cover.jpg' %>" class="thumbnail-img"></a></div><div class="body"><h5 class="paper-title"><%- item.title %></h5><% if (item.with) { %><div class="paper-authors"><em>with <%= item.with %></em></div><% } %><% if (item.journal) { %><div class="paper-venue"><span class="venue-status">submitted to</span><span class="venue-name"><%= item.journal %></span><% if (item.year) { %><span class="venue-sep">&middot;</span><span class="venue-year"><%= item.year %></span><% } %></div><% } %><% if (item.links) { %><div class="paper-links"><% let first = true; for (const [venue, link] of Object.entries(item.links)) { if (!first) { %><span class="venue-sep">&middot;</span><% } first = false; %><a href="<%- link %>"><%= venue %></a><% } %></div><% } %><% if (item.categories && item.categories.length) { %><div class="paper-tags"><% for (const [id, name] of Object.entries(item.categories)) { %><span class="paper-tag" onclick="window.quartoListingCategory('<%= name %>'); return false;"><%= name %></span><% } %></div><% } %></div></div><% } %></div>
