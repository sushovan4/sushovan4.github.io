        "content"  : "<h1 style=\"text-align: center;\">গবেষণা</h1>\n\n  <p class=\"relaxed\">\n    Research Interests:<br>\n    &nbsp;&nbsp;&ndash; Topological Data Analysis<br>\n    &nbsp;&nbsp;&ndash; Computational Topology<br>\n    &nbsp;&nbsp;&ndash; Applied Algebraic Topology<br>\n    &nbsp;&nbsp;&ndash; Big Data Analysis<br>\n    &nbsp;&nbsp;&ndash; Computational Geometry<br>\n\n    Download my <a href=\"/assets/cv.pdf\" download>academic CV</a>\n    and <a href=\"/assets/research.pdf\" download>research statement</a> here.\n    <br><br>\n    \n    The following is a list of my research groups/topics that I am currently\n    involved in.\n</p>\n\n<section id=\"projects\">\n  <div class=\"header\">\n    Research Projects    \n  </div>\n  <div class=\"two cards\">\n  \n  <a class=\"card\" href=\"/research-projects/gh.html\">\n  <div class=\"avatar\">\n    <img class=\"image\" src=\"/assets/projects/recon/graph-rips.jpg\">\n  </div>\n  <div class=\"content\">\n    <div class=\"title\">\n      \n      Approximating Gromov-Hausdorff Distance\n    </div>  \n  </div>\n</a>\n\n  <a class=\"card\" href=\"/research-projects/morse.html\">\n  <div class=\"avatar\">\n    <img class=\"image\" src=\"/assets/projects/recon/graph-rips.jpg\">\n  </div>\n  <div class=\"content\">\n    <div class=\"title\">\n      \n      Graph Reconstruction via Discrete Morse Theory\n    </div>  \n  </div>\n</a>\n\n  <a class=\"card\" href=\"/research/shape-construction\">\n  <div class=\"avatar\">\n    <img class=\"image\" src=\"/assets/projects/recon/graph-rips.jpg\">\n  </div>\n  <div class=\"content\">\n    <div class=\"title\">\n      \n      Shape Reconstruction\n    </div>  \n  </div>\n</a>\n\n</div>\n</section>\n\n<section id=\"publications\">\n  <div class=\"header\">\n  Publications\n</div>\n      <div class=\"timeline\">\n        <div class=\"item\" data-year=\"2020\">\n          <p><a class=\"styled\" href=\"/thesis.html\">PhD Thesis</a>, published on <i>ProQuest</i>.</p>\n        </div>\n        \n        <div class=\"item\" data-year=\"2019\">\n          <p><fullcite>majhi2019approximating</fullcite></p>\n        </div>\n\n        <div class=\"item\" data-year=\"2018\">\n          <p><fullcite>fasy2018reconstruction</fullcite> submitted to <i>Journal of Computational Geometry</i></p>\n          <div class=\"ui divider\"></div>\n          <p><fullcite>fw18</fullcite></p>\n        </div>\n\n        <div class=\"item\" data-year=\"2017\">\n          <p><fullcite>fw17</fullcite></p> \n        </div>\n      </div>\n\n</section>\n\n<script>\n  $(document).ready(function( ){\n   $('.menu .research.item').addClass('active');\n  });\n</script>"
     
